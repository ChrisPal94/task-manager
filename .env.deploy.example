# Deploy configuration — copy this file to .env.deploy and fill in your values.
# .env.deploy is gitignored and should NEVER be committed.

# Elastic Beanstalk environment name
EB_ENV=task-manager-prod

# S3 bucket name (frontend static assets)
S3_BUCKET=your-s3-bucket-name

# CloudFront distribution ID
CF_DISTRIBUTION_ID=EXXXXXXXXXX
